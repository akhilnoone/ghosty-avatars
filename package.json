{
  "name": "ghosty-avatars",
  "version": "0.1.0",
  "description": "Ghosty Avatars — deterministic animated avatars powered by Rive. Same name = same face, always.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./avatar.riv": "./assets/avatar.riv"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "avatar",
    "rive",
    "deterministic",
    "hash",
    "face",
    "animated",
    "react",
    "profile-picture",
    "identicon"
  ],
  "author": "Akhil Noone",
  "license": "MIT",
  "homepage": "https://www.linkedin.com/in/akhil-noone",
  "repository": {
    "type": "git",
    "url": "https://github.com/akhilnoone/ghosty-avatars"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@rive-app/react-canvas": ">=4",
    "@rive-app/canvas": ">=4"
  },
  "peerDependenciesMeta": {
    "react": { "optional": false },
    "react-dom": { "optional": false },
    "@rive-app/react-canvas": { "optional": false },
    "@rive-app/canvas": { "optional": false }
  },
  "devDependencies": {
    "@rive-app/react-canvas": "^4.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
